{
  "manifest_version": 3,
  "name": "GOG Enhancer",
  "version": "2.5.0",
  "description": "תוסף third-party (לא רשמי) ל-GOG.com: המרת מטבע חיה, מעקב היסטוריית מחירים, תגיות, עברית + RTL.",

  "permissions": ["storage", "activeTab", "alarms", "notifications"],
  "host_permissions": [
    "https://www.gog.com/*",
    "https://api.frankfurter.app/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GOG Enhancer Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.gog.com/*"],
      "js": [
        "lib/defaults.js",
        "lib/storage.js",
        "content/translations.js",
        "content/currency-detection.js",
        "content/price-history.js",
        "content/tooltips.js",
        "content/toasts.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css",
        "content/design-injection.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+G"
      },
      "description": "Open GOG Enhancer settings"
    },
    "toggle-master": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Toggle GOG Enhancer on/off"
    },
    "toggle-hebrew": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Toggle Hebrew translations"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://www.gog.com/*"]
    }
  ]
}
